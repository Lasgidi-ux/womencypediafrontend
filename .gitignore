# ============================================
# Womencypedia — .gitignore
# SECURITY: This file MUST be the first file in every project
# ============================================

# ─── ENVIRONMENT & SECRETS (CRITICAL) ───────
# NEVER commit secrets to version control
.env
.env.*
.env.local
.env.development
.env.staging
.env.production
*.pem
*.key
*.cert
*.secret

# ─── Dependencies ───────────────────────────
node_modules/
package-lock.json
yarn.lock

# ─── OS files ───────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── IDE / Editor ───────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ─── Logs ───────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Temporary files ───────────────────────
*.tmp
*.temp
*.bak
*.orig

# ─── Strapi CMS ─────────────────────────────
womencypedia-cms/.tmp/
womencypedia-cms/dist/
womencypedia-cms/.strapi/
womencypedia-cms/database/
womencypedia-cms/.cache/
womencypedia-cms/exports/
womencypedia-cms/node_modules/
womencypedia-cms/.env
womencypedia-cms/.env.*

# ─── Build artifacts ────────────────────────
dist/
build/
css/tailwind.css.map

# ─── Script-generated reports ───────────────
scripts/*.json
!scripts/translation-keys.json

# ─── Python helper scripts (dev-only) ───────
__pycache__/
*.pyc
*.pyo

# ─── Setup/install logs (one-time use) ──────
cms_setup.log
strapi_install.log
strapi_setup_log.txt

# ─── AI agent files ─────────────────────────
.gemini/
.cursor/
.copilot/
