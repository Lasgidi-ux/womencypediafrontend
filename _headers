# ============================================
# Womencypedia — Cloudflare Pages Headers
# Replaces .htaccess for Cloudflare hosting
# ============================================

# ─── Global Security Headers ────────────────
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
   Content-Security-Policy: default-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://fonts.googleapis.com https://plausible.io https://cdn.jsdelivr.net https://js.paystack.co https://checkout.flutterwave.com https://cdn.tailwindcss.com https://app.launchdarkly.com https://events.launchdarkly.com https://img1.wsimg.com https://unpkg.com https://d3js.org https://static.cloudflareinsights.com https://beacon.tildacdn.com https://script.tildacdn.com https://general.tildacdn.com https://womencypedia.org; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com https://unpkg.com; img-src 'self' data: blob: https:; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https://*.onrender.com https://plausible.io https://app.launchdarkly.com https://events.launchdarkly.com https://*.tile.openstreetmap.org https://unpkg.com https://img1.wsimg.com https://d3js.org https://fonts.googleapis.com https://fonts.gstatic.com https://analytics.strapi.io https://cloudflareinsights.com https://beacon.tildacdn.com https://*.tildacdn.com https://*.jsdelivr.net https://*.gstatic.com https://*.googleapis.com https://womencypedia.org; frame-src https://js.paystack.co https://checkout.flutterwave.com; worker-src 'self' blob: https://womencypedia.org; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# ─── Cache: Minified JS (1 year, immutable) ─
/dist/*
  Cache-Control: public, max-age=31536000, immutable

# ─── Cache: CSS (1 year, immutable) ─────────
/css/*
  Cache-Control: public, max-age=31536000, immutable

# ─── Cache: Images (1 day) ──────────────────
/images/*
  Cache-Control: public, max-age=86400

# ─── Cache: Fonts (1 year) ──────────────────
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# ─── Cache: Locale JSON (1 hour) ────────────
/locales/*
  Cache-Control: public, max-age=3600

# ─── Correct MIME for manifest ──────────────
/manifest.json
  Content-Type: application/json
  Cache-Control: public, max-age=86400
