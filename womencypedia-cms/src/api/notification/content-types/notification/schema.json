{
    "kind": "collectionType",
    "collectionName": "notifications",
    "info": {
        "singularName": "notification",
        "pluralName": "notifications",
        "displayName": "Notification",
        "description": "User notifications"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "message": {
            "type": "text",
            "required": true
        },
        "type": {
            "type": "enumeration",
            "enum": [
                "comment",
                "like",
                "follow",
                "system",
                "contribution",
                "verification"
            ],
            "default": "system"
        },
        "read": {
            "type": "boolean",
            "default": false
        },
        "user": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "plugin::users-permissions.user"
        },
        "link": {
            "type": "string"
        }
    }
}