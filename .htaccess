<IfModule mod_headers.c>
    # Content Security Policy for Womencypedia
    #
    # IMPORTANT SECURITY NOTES:
    # - This is the AUTHORITATIVE CSP for GoDaddy cPanel deployments.
    # - HTML meta CSP tags have been removed; this server header is the single source.
    #
    # Third-party scripts and their purposes:
    # - https://plausible.io - Privacy-friendly analytics
    # - https://js.paystack.co - Payment processing (Nigeria)
    # - https://checkout.flutterwave.com - Payment processing (Africa)
    # - https://fonts.googleapis.com - Google Fonts
    # - https://d3js.org - Data visualization
    # - https://img1.wsimg.com - GoDaddy platform scripts (required on GoDaddy hosting)
    #
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://plausible.io https://cdn.jsdelivr.net https://js.paystack.co https://checkout.flutterwave.com https://unpkg.com https://app.launchdarkly.com https://img1.wsimg.com https://d3js.org; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com; img-src 'self' https: data: blob:; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https://womencypedia-cms.onrender.com https://plausible.io https://unpkg.com https://img1.wsimg.com https://d3js.org https://*.onrender.com https://fonts.googleapis.com https://fonts.gstatic.com https://app.launchdarkly.com https://events.launchdarkly.com https://analytics.strapi.io https://*.tile.openstreetmap.org https://csp.secureserver.net; frame-src https://js.paystack.co https://checkout.flutterwave.com; worker-src 'self' blob:;"
    
    # Prevent MIME-type sniffing
    Header set X-Content-Type-Options "nosniff"
    
    # Prevent clickjacking
    Header set X-Frame-Options "DENY"
    
    # Control referrer information
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Legacy XSS protection (still useful for older browsers)
    Header set X-XSS-Protection "1; mode=block"

    # HSTS - Force HTTPS for 1 year (includeSubDomains for full coverage)
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Permissions Policy - Block invasive browser APIs you don't use
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(self), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"
</IfModule>

# ─── BLOCK ACCESS TO SENSITIVE FILES ────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block .git directory and files
    RewriteRule ^\.git(/|$) - [F,L]

    # Block .env files
    RewriteRule ^\.env - [F,L]

    # Block .cpanel.yml
    RewriteRule ^\.cpanel\.yml$ - [F,L]

    # Block scripts directory from direct access
    RewriteRule ^scripts/ - [F,L]

    # Block node_modules if accidentally deployed
    RewriteRule ^node_modules/ - [F,L]

    # Block docs directory (internal documentation)
    RewriteRule ^docs/ - [F,L]

    # Block womencypedia-cms directory on frontend
    RewriteRule ^womencypedia-cms/ - [F,L]

    # Redirect HTTP to HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # ─── HOTLINK PROTECTION ─────────────────────────────────
    # Prevent other sites from embedding your images (bandwidth theft)
    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?womencypedia\.org [NC]
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?google\. [NC]
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?bing\. [NC]
    RewriteRule \.(jpg|jpeg|png|gif|webp|svg)$ - [F,NC,L]
</IfModule>

# Block sensitive file types by name (NOT by extension broadly)
# This avoids blocking manifest.json and locale .json files
# Using Apache 2.2/2.4 dual-compatible syntax for GoDaddy shared hosting
<FilesMatch "^\.env">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

<FilesMatch "^\.git">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

<FilesMatch "^(package\.json|package-lock\.json)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

<FilesMatch "^(tailwind\.config\.js|\.gitignore)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Block sensitive extensions that have no legitimate web use
<FilesMatch "\.(sql|bak|orig|tmp|log)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Enable GZIP compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Cache static assets (reduced to 1 month for JS/CSS to allow updates)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
</IfModule>
